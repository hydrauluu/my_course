# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret
GITHUB_BOT_TOKEN=your_github_personal_access_token

# Claude API
CLAUDE_API_KEY=your_claude_api_key

# Teacher
TEACHER_GITHUB_USERNAME=your_github_username

# Seed (set to 1 to update lecture content from scr/ on each seed run)
SEED_UPDATE_CONTENT=0

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60/minute
