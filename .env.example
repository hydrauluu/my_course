# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret
GITHUB_BOT_TOKEN=your_github_personal_access_token

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Teacher
TEACHER_GITHUB_USERNAME=your_github_username

# JWT (REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))")
JWT_SECRET=

# Seed (set to 1 to update lecture content from scr/ on each seed run)
SEED_UPDATE_CONTENT=1

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60/minute

# Cookie security (set to false for local HTTP dev, true for production HTTPS)
COOKIE_SECURE=false

# CSRF protection
CSRF_ENABLED=true
